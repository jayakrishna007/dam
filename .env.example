# Google Analytics (Optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# MongoDB Native Connection URI (Server-side environment variable in Vercel)
# Format: mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://admin:pass123@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority
